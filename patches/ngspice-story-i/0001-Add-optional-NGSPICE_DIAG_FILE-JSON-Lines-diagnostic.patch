@@ -0,0 +1,17 @@
+#ifndef NGSPICE_DIAGHOOKS_H
+#define NGSPICE_DIAGHOOKS_H
+
+#include <stdio.h>
+
+extern FILE *ngspice_diag_fp;
+
+#define DIAG_EMIT(...) \
+    do { \
+        if (ngspice_diag_fp) \
+            fprintf(ngspice_diag_fp, __VA_ARGS__); \
