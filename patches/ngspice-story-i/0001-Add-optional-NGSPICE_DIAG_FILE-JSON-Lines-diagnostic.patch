@@ -56,10 +56,12 @@
  *    Matrix type and macro definitions for the sparse matrix routines.
  */
 #include <assert.h>
+#include <math.h>
 
 #define spINSIDE_SPARSE
 #include "spconfig.h"
 #include "ngspice/spmatrix.h"
+#include "ngspice/diaghooks.h"
 #include "spdefs.h"
 
 
@@ -92,6 +94,46 @@ static ElementPtr CreateFillin( MatrixPtr, int, int );
 static int  MatrixIsSingular( MatrixPtr, int );
 static int  ZeroPivot( MatrixPtr, int );
 
+/* Emit min/max diagonal pivot magnitudes after successful real LU (Story I). */
+static void
+diag_emit_matrix_factored(MatrixPtr Matrix)
+{
+    int Step, Size;
+    double min_piv, max_piv, ratio, piv, d;
+
+    if (!ngspice_diag_fp)
+        return;
+    if (Matrix->Complex)
+        return;
+    if (!Matrix->Factored)
+        return;
+    Size = Matrix->Size;
+    if (Size <= 0)
+        return;
+
+    min_piv = 1e300;
+    max_piv = 0.0;
+    for (Step = 1; Step <= Size; Step++) {
+        d = fabs((double) Matrix->Diag[Step]->Real);
+        if (d < 1e-300)
+            continue;
+        piv = 1.0 / d;
+        if (!isfinite(piv))
+            continue;
+        if (piv < min_piv)
+            min_piv = piv;
+        if (piv > max_piv)
+            max_piv = piv;
+    }
+    if (min_piv >= 1e299 || max_piv <= 0.0 || !isfinite(min_piv) || !isfinite(max_piv))
+        return;
+    ratio = max_piv / min_piv;
+    if (!isfinite(ratio))
+        return;
+    DIAG_EMIT("{\"hook\":\"matrix\",\"size\":%d,\"min_piv\":%.6e,\"max_piv\":%.6e,\"ratio\":%.6e}\n",
+              Size, min_piv, max_piv, ratio);
+}
+
 
 
 /*
@@ -280,6 +322,9 @@ Done:
     Matrix->Reordered = YES;
     Matrix->Factored = YES;
 
+    if (Matrix->Error == spOKAY && !Matrix->Complex)
+        diag_emit_matrix_factored(Matrix);
+
     return Matrix->Error;
 }
 
@@ -410,6 +455,7 @@ spFactor(MatrixPtr Matrix)
     }
 
     Matrix->Factored = YES;
+    diag_emit_matrix_factored(Matrix);
     return (Matrix->Error = spOKAY);
 }
 
